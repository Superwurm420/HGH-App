{
  "name": "hgh-app",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler dev",
    "build": "next build",
    "build:worker": "wrangler deploy --dry-run",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "vitest run",
    "db:migrate": "wrangler d1 migrations apply hgh-app-db",
    "db:migrate:local": "wrangler d1 migrations apply hgh-app-db --local",
    "setup": "bash scripts/setup.sh",
    "setup:local": "bash scripts/setup.sh --local",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "next": "14.2.32",
    "pdfjs-dist": "^5.4.624",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "20.17.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.32",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
