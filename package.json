{
  "name": "hgh-app",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worker": "opennextjs-cloudflare dev",
    "dev:api": "wrangler dev -c worker/wrangler.toml",
    "build": "npm run build:web",
    "build:web": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "db:migrate": "wrangler d1 migrations apply hgh-app-db -c worker/wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply hgh-app-db --local -c worker/wrangler.toml",
    "setup": "npm run setup:init -- --local",
    "deploy:web": "opennextjs-cloudflare deploy",
    "deploy:api": "wrangler deploy -c worker/wrangler.toml",
    "deploy": "npm run deploy:web && npm run deploy:api",
    "preview:worker": "opennextjs-cloudflare preview",
    "build:next": "next build",
    "setup:cloudflare": "npm run setup:init -- --cloudflare",
    "setup:init": "node scripts/setup.mjs"
  },
  "dependencies": {
    "next": "^16.1.6",
    "pdfjs-dist": "^5.4.624",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "20.17.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0",
    "@opennextjs/cloudflare": "^1.8.0"
  }
}
