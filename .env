# Admin-Zugang für /admin und /api/admin/*
# Benutzername + Passwort werden beim Login geprüft.
ADMIN_USER=Admin
ADMIN_PASSWORD=hgh-admin

# Optional, aber empfohlen: separates Secret zum Signieren des Session-Cookies
SESSION_SECRET=BitteLangesZufaelligesSecretSetzen

# ── Cloudflare Bindings (automatisch über wrangler.toml) ──────
# D1-Datenbank und R2-Bucket werden in wrangler.toml konfiguriert.
# Lokale Entwicklung: wrangler dev (startet D1 + R2 lokal)
#
# ── Next.js Frontend (optional) ──────────────────────────────
# Nur setzen wenn das Frontend auf einem anderen Host als der Worker läuft.
# NEXT_PUBLIC_API_URL=http://localhost:8787
