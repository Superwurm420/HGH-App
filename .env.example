# Admin-Zugang für /admin und /api/admin/*
# Benutzername + Passwort werden beim Login geprüft.
ADMIN_USER=redaktion
ADMIN_PASSWORD=BitteSicheresPasswortSetzen123!

# Optional, aber empfohlen: separates Secret zum Signieren des Session-Cookies
SESSION_SECRET=BitteLangesZufaelligesSecretSetzen

# ── Supabase (Pflicht in Production) ──────────────────────────
# Supabase-Projekt-URL (z.B. https://xyz.supabase.co)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co

# Anon-Key für öffentliche Lesezugriffe (optional, wird aktuell nicht im Client-Bundle genutzt)
SUPABASE_ANON_KEY=eyJ...

# Service-Role-Key für serverseitige Schreibzugriffe (NIEMALS im Client-Bundle!)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Lokaler Fallback (Development) ────────────────────────────
# Setzt man CONTENT_STORE_PROVIDER=local, wird kein Supabase benötigt.
# In Development wird automatisch lokal gespeichert, wenn SUPABASE_URL fehlt.
# CONTENT_STORE_PROVIDER=local

# Optionaler lokaler Pfad für den Local-Store (nur bei CONTENT_STORE_PROVIDER=local)
LOCAL_CONTENT_STORE_DIR=data/content-store
