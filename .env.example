# Admin-Zugang für /admin und /api/admin/*
ADMIN_USER=redaktion
ADMIN_PASSWORD=BitteSicheresPasswortSetzen123!

# Optional, aber empfohlen: separates Secret zum Signieren des Session-Cookies
SESSION_SECRET=BitteLangesZufaelligesSecretSetzen

# Storage-Provider für serverseitige Inhaltsdateien
# Standard: vercel-blob
# Unterstützte Werte: vercel-blob | local
CONTENT_STORE_PROVIDER=vercel-blob

# Pflicht in Production bei CONTENT_STORE_PROVIDER=vercel-blob,
# sofern kein expliziter Local-Fallback aktiviert ist.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Optionaler lokaler Pfad für den Local-Store
LOCAL_CONTENT_STORE_DIR=data/content-store

# Optional: erlaubt in Production den lokalen Fallback, wenn
# CONTENT_STORE_PROVIDER=vercel-blob und BLOB_READ_WRITE_TOKEN fehlt.
# Nützlich für Self-Hosting ohne Vercel Blob.
ALLOW_LOCAL_STORE_IN_PROD=false
